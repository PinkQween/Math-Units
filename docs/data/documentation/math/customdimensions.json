{"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"url":"doc:\/\/Math\/documentation\/Math\/CustomDimensions","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"Overview"},{"inlineContent":[{"text":"While the ","type":"text"},{"code":"Math","type":"codeVoice"},{"text":" library defines a comprehensive set of standard SI dimensions (like ","type":"text"},{"code":"length","type":"codeVoice"},{"text":", ","type":"text"},{"code":"time","type":"codeVoice"},{"text":") and derived dimensions (like ","type":"text"},{"code":"velocity","type":"codeVoice"},{"text":", ","type":"text"},{"code":"energy","type":"codeVoice"},{"text":"), you may want to define your own custom dimensions—such as currency, resource points, or custom gameplay metrics.","type":"text"}],"type":"paragraph"},{"text":"Defining a Custom Dimension","type":"heading","level":3,"anchor":"Defining-a-Custom-Dimension"},{"inlineContent":[{"text":"To define a custom dimension at runtime, instantiate ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Math\/documentation\/Math\/PhysicalDimension"},{"text":" with a dictionary of custom exponent identifiers:","type":"text"}],"type":"paragraph"},{"code":["let usdDimension = PhysicalDimension(exponents: [\"USD\": 1])"],"type":"codeListing","syntax":"swift"},{"text":"Defining Custom Units","type":"heading","level":3,"anchor":"Defining-Custom-Units"},{"inlineContent":[{"text":"Once you have a dimension, you can construct custom ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Math\/documentation\/Math\/NamedUnit"},{"text":" instances. Because custom dimensions do not have a pre-defined static type, use the ","type":"text"},{"code":"MathDimension.unknown","type":"codeVoice"},{"text":" compile-time type-level parameter:","type":"text"}],"type":"paragraph"},{"code":["let usdUnit = NamedUnit<MathDimension.unknown>(","    symbol: \"$\",","    dimension: usdDimension,","    converter: LinearConverter(coefficient: 1.0)",")","","let eurUnit = NamedUnit<MathDimension.unknown>(","    symbol: \"€\",","    dimension: usdDimension,","    converter: LinearConverter(coefficient: 1.09) \/\/ Conversion rate relative to USD base",")"],"type":"codeListing","syntax":"swift"},{"text":"Dynamic Conversion","type":"heading","level":3,"anchor":"Dynamic-Conversion"},{"inlineContent":[{"text":"You can perform conversions between custom units just like standard units:","type":"text"}],"type":"paragraph"},{"code":["let walletInEur = Quantity(value: 100.0, unit: eurUnit)","let walletInUsd = walletInEur.converted(to: usdUnit)","print(walletInUsd.value) \/\/ 109.0"],"type":"codeListing","syntax":"swift"}]}],"metadata":{"title":"Custom Dimensions and Units","roleHeading":"Article","role":"article","modules":[{"name":"Math"}]},"kind":"article","sections":[],"variants":[{"paths":["\/documentation\/math\/customdimensions"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/Math\/documentation\/Math"]]},"abstract":[{"text":"How to extend the library with your own custom physical dimensions and units at runtime.","type":"text"}],"references":{"doc://Math/documentation/Math/PhysicalDimension":{"title":"PhysicalDimension","identifier":"doc:\/\/Math\/documentation\/Math\/PhysicalDimension","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"kind":"identifier","text":"PhysicalDimension"}],"abstract":[{"type":"text","text":"A type representing a physical dimension as a canonical dictionary of base SI dimension exponents."}],"url":"\/documentation\/math\/physicaldimension","role":"symbol","navigatorTitle":[{"text":"PhysicalDimension","kind":"identifier"}],"kind":"symbol"},"doc://Math/documentation/Math":{"type":"topic","abstract":[{"type":"text","text":"A robust, type-safe dimensional analysis and unit conversion library for Swift."}],"identifier":"doc:\/\/Math\/doc