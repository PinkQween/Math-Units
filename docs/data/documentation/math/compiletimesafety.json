{"identifier":{"url":"doc:\/\/Math\/documentation\/Math\/CompileTimeSafety","interfaceLanguage":"swift"},"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"inlineContent":[{"text":"Historically, physical dimensions were evaluated strictly at runtime in the ","type":"text"},{"type":"codeVoice","code":"Math"},{"text":" library. To enable compile-time guarantees, the library now features the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/Math\/documentation\/Math\/DimensionProtocol"},{"text":" and the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/Math\/documentation\/Math\/Dimension"},{"text":" type namespace.","type":"text"}],"type":"paragraph"},{"anchor":"The-Problem","type":"heading","text":"The Problem","level":3},{"inlineContent":[{"text":"When writing generic APIs that accept quantities, you often want to ensure that a quantity represents a specific dimension (e.g., length, not time) before running your function:","type":"text"}],"type":"paragraph"},{"code":["import CoreLocation","import Math","","protocol PlaceService {","    func fetchNearbyPlaces<U: Unit>(","        coordinate: CLLocationCoordinate2D,","        radius: Math.Quantity<U>,","        completion: @escaping (Result<[Place], Error>) -> Void","    ) where U.Dimension == Dimension.length \/\/ Compile-time check!","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"By parameterizing ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/Math\/documentation\/Math\/NamedUnit"},{"text":" with a compile-time dimension type (e.g., ","type":"text"},{"type":"codeVoice","code":"NamedUnit<Dimension.length>"},{"text":"), Swift’s compiler can enforce that you only pass length units into this method.","type":"text"}],"type":"paragraph"},{"anchor":"How-to-Use-It","type":"heading","text":"How to Use It","level":3},{"inlineContent":[{"text":"All standard units generated by the ","type":"text"},{"type":"codeVoice","code":"@PrefixedUnits"},{"text":" macro or declared in ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/Math\/documentation\/Math\/Units"},{"text":" are parameterized by their respective dimension type.","type":"text"}],"type":"paragraph"},{"anchor":"Passing-Correct-Units","type":"heading","text":"Passing Correct Units","level":4},{"code":["\/\/ Compiles perfectly!","let radius = Quantity(value: 500, unit: Units.meter)","placeService.fetchNearbyPlaces(coordinate: coords, radius: radius) { ... }"],"syntax":"swift","type":"codeListing"},{"anchor":"Prevent-Mismatched-Units","type":"heading","text":"Prevent Mismatched Units","level":4},{"code":["\/\/ Mismatched dimension (time vs length) - Compiler Error!","let timeLimit = Quantity(value: 30, unit: Units.minute)","placeService.fetchNearbyPlaces(coordinate: coords, radius: timeLimit) { ... }"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"sections":[],"metadata":{"role":"article","modules":[{"name":"Math"}],"roleHeading":"Article","title":"Compile-Time Dimension Type Safety"},"kind":"article","schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/math\/compiletimesafety"]}],"abstract":[{"text":"Learn how to enforce dimension constraints at compile time using unit generic parameters.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/Math\/documentation\/Math"]]},"references":{"doc://Math/documentation/Math/DimensionProtocol":{"abstract":[{"type":"text","text":"A protocol representing a type-level identifier for a physical dimension."},{"type":"text","text":" "},{"type":"text","text":"Conforming types provide the underlying runtime "},{"type":"codeVoice","code":"PhysicalDimension"},{"text":" value.","type":"text"}],"identifier":"doc:\/\/Math\/documentation\/Math\/DimensionProtocol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":