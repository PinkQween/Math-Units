{"abstract":[{"type":"text","text":"Learn how to enforce dimension constraints at compile time using unit generic parameters."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Math\/documentation\/Math\/CompileTimeSafety"},"metadata":{"roleHeading":"Article","modules":[{"name":"Math"}],"title":"Compile-Time Dimension Type Safety","role":"article"},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Overview","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Historically, physical dimensions were evaluated strictly at runtime in the "},{"type":"codeVoice","code":"Math"},{"type":"text","text":" library. To enable compile-time guarantees, the library now features the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Math\/documentation\/Math\/DimensionProtocol"},{"type":"text","text":" and the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Math\/documentation\/Math\/MathDimension"},{"type":"text","text":" type namespace."}]},{"type":"heading","anchor":"The-Problem","text":"The Problem","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"When writing generic APIs that accept quantities, you often want to ensure that a quantity represents a specific dimension (e.g., length, not time) before running your function:"}]},{"type":"codeListing","syntax":"swift","code":["import CoreLocation","import Math","","protocol PlaceService {","    func fetchNearbyPlaces<U: MathUnit>(","        coordinate: CLLocationCoordinate2D,","        radius: Math.Quantity<U>,","        completion: @escaping (Result<[Place], Error>) -> Void","    ) where U.Dimension == MathDimension.length \/\/ Compile-time check!","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"By parameterizing "},{"type":"reference","identifier":"doc:\/\/Math\/documentation\/Math\/NamedUnit","isActive":true},{"type":"text","text":" with a compile-time dimension type (e.g., "},{"type":"codeVoice","code":"NamedUnit<MathDimension.length>"},{"type":"text","text":"), Swift’s compiler can enforce that you only pass length units into this method."}]},{"type":"heading","anchor":"How-to-Use-It","text":"How to Use It","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"All standard units generated by the "},{"type":"codeVoice","code":"@PrefixedUnits"},{"type":"text","text":" macro or declared in "},{"type":"reference","identifier":"doc:\/\/Math\/documentation\/Math\/Units","isActive":true},{"type":"text","text":" are parameterized by their respective dimension type."}]},{"type":"heading","anchor":"Passing-Correct-Units","text":"Passing Correct Units","level":4},{"type":"codeListing","syntax":"swift","code":["\/\/ Compiles perfectly!","let radius = Quantity(value: 500, unit: Units.meter)","placeService.fetchNearbyPlaces(coordinate: coords, radius: radius) { ... }"]},{"type":"heading","anchor":"Prevent-Mismatched-Units","text":"Prevent Mismatched Units","level":4},{"type":"codeListing","syntax":"swift","code":["\/\/ Mismatched dimension (time vs length) - Compiler Error!","let timeLimit = Quantity(value: 30, unit: Units.minute)","placeService.fetchNearbyPlaces(coordinate: coords, radius: timeLimit) { ... }"]}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/Math\/documentation\/Math"]]},"kind":"article","variants":[{"paths":["\/documentation\/math\/compiletimesafety"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://Math/documentation/Math":{"type":"topic","abstract":[{"type":"text","text":"A robust, type-safe dimensional analysis and unit conversion library for Swift."}],"identifier":"doc:\/\/Math\/documentation\/Math","url":"\/documentation\/math","title":"Math","role":"collection","kind":"symbol"},"doc://Math/documentation/Math/MathDimension":{"title":"MathDimension","url":"\/documentation\/math\/mathdimension","identifier":"doc:\/\/Math\/documentation\/Math\/MathDimension","role":"symbol","navigatorTitle":[{"text":"MathDimension","kind":"identifier"}],"kind":"symbol","type":"topic","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MathDimension","kind":"identifier"}],"abstract":[{"type":"text","text":"A namespace containing type-level structures for compile-time physical dimension verification."}]},"doc://Math/documentation/Math/NamedUnit":{"abstract":[{"type":"text","text":"A generic unit implementation representing a measurement unit associated with a specific compile-time dimension type."}],"type":"topic","url":"\/documentation\/math\/namedunit","identifier":"doc:\/\/Math\/documentation\/Math\/NamedUnit","title":"NamedUnit","role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"text":" ","kind":"text"},{"text":"NamedUnit","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"NamedUnit"}]},"doc://Math/documentation/Math/DimensionProtocol":{"title":"DimensionProtocol","identifier":"doc:\/\/Math\/documentation\/Math\/DimensionProtocol","type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DimensionProtocol","kind":"identifier"}],"abstract":[{"text":"A protocol representing a type-level identifier for a physical dimension.","type":"text"},{"text":" ","type":"text"},{"text":"Conforming types provide the underlying runtime ","type":"text"},{"code":"PhysicalDimension","type":"codeVoice"},{"text":" value.","type":"text"}],"url":"\/documentation\/math\/dimensionprotocol","role":"symbol","navigatorTitle":[{"text":"DimensionProtocol","kind":"identifier"}],"kind":"symbol"},"doc://Math/documentation/Math/Units":{"abstract":[],"type":"topic","url":"\/documentation\/math\/units","identifier":"doc:\/\/Math\/documentation\/Math\/Units","title":"Units","role":"symbol","kind":"symbol","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Units","kind":"identifier"}],"navigatorTitle":[{"text":"Units","kind":"identifier"}]}}}